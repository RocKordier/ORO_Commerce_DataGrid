{
    "name": "genaker/data-grid-bundle",
    "description": "A generic data grid bundle for OroCommerce with Product sample. Supports Grid.js, DataTables, Tabulator, AG Grid.",
    "type": "oro-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Yehor Shytikov",
            "email": "yehor@genaker.com"
        }
    ],
    "require": {
        "php": "~8.4.0",
        "oro/platform": "6.1.*"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Genaker\\Bundle\\DataGridBundle\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/runtime": true,
            "symfony/flex": true,
            "phpstan/extension-installer": true
        }
    }
}
